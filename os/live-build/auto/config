#!/bin/sh
# FoulFox OS — live-build configuration.
#
# Debian/Ubuntu-family live image with a broad firmware set (plug-and-play
# networking + drivers), the QEMU/KVM stack, and a graphical kiosk session that
# autostarts the FoulFox VM shell. Run via `lb config` (see scripts/build-image.sh).
set -e

# NOTE on the Debian security pocket: the live-build shipped on the CI runner
# predates Debian's bullseye-era rename of the security suite, so it auto-
# generates the obsolete "<dist>/updates" name (e.g. "bookworm/updates"), which
# 404s on security.debian.org and aborts the chroot apt stage. We turn off
# live-build's built-in security source (--security false) and instead ship the
# correct "<dist>-security" source via config/archives/debian-security.list.*.
# The Debian archive keyring already trusts this repo, so no key import needed.
#
# NOTE on firmware: live-build's automatic firmware detection (--firmware-chroot
# / --firmware-binary "true") downloads the per-suite Contents index from
# "<mirror>/dists/bookworm/Contents-amd64.gz" to map kernel modules to firmware
# packages. deb.debian.org only serves Contents under a component path
# ("dists/bookworm/<area>/Contents-amd64.gz"), so that top-level URL 404s and
# aborts the chroot_linux-image stage. We turn the auto-detection OFF ("false")
# and instead install the firmware bundles explicitly via
# config/package-lists/foulfox.list.chroot (firmware-linux, firmware-iwlwifi, …),
# which keeps broad plug-and-play hardware support without the broken lookup.
lb config noauto \
  --mode debian \
  --distribution bookworm \
  --mirror-bootstrap "http://deb.debian.org/debian/" \
  --mirror-chroot "http://deb.debian.org/debian/" \
  --mirror-chroot-security "http://security.debian.org/debian-security/" \
  --mirror-binary "http://deb.debian.org/debian/" \
  --mirror-binary-security "http://security.debian.org/debian-security/" \
  --security false \
  --architectures amd64 \
  --linux-flavours amd64 \
  --archive-areas "main contrib non-free non-free-firmware" \
  --debian-installer none \
  --memtest none \
  --apt-recommends true \
  --firmware-chroot false \
  --firmware-binary false \
  --bootappend-live "boot=live components username=foulfox user-fullname=FoulFox hostname=foulfox persistence persistence-label=foulfox-persist" \
  "${@}"
