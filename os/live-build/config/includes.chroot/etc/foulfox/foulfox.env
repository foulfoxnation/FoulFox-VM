# FoulFox OS runtime environment.
# Sourced by the systemd services, the first-run provisioner, and the kiosk.
# These are appliance defaults; foulfox-first-run composes the VM config the
# api-server reads (/var/lib/foulfox/.odysseus-vm-config.json) from them.

HOME=/var/lib/foulfox
NODE_ENV=production

# Shared persistent data root (on the foulfox-persist overlay). Both the
# api-server (VM registry/config) and the Odysseus FastAPI agent honor
# ODYSSEUS_DATA_DIR, so pinning it keeps ALL mutable state in one place under
# the persistence partition instead of the read-only app dir.
ODYSSEUS_DATA_DIR=/var/lib/foulfox

# Paths below resolve through /var/lib/foulfox/app-current — a symlink to the
# active app release that foulfox-patcher flips for live updates (defaults to the
# baked /opt/foulfox/app). Keeps the shell + Odysseus dirs swappable in lockstep.

# ── api-server (Express): serves the built shell + /api + Odysseus proxy ─────
PORT=8080
HOST=127.0.0.1
SERVE_SHELL_STATIC=1
SHELL_STATIC_DIR=/var/lib/foulfox/app-current/artifacts/odysseus-shell/dist/public

# ── Odysseus FastAPI agent (loopback; proxied by api-server) ─────────────────
ODYSSEUS_PORT=7000
ODYSSEUS_DIR=/var/lib/foulfox/app-current/artifacts/odysseus-service

# ── Live app updates (foulfox-patcher) ──────────────────────────────────────
# The patcher pulls a checksummed app bundle from a rolling GitHub release and
# swaps it in atomically with a health-checked, automatic rollback — no reflash.
# It reuses FOULFOX_GITHUB_REPO (the same var /api/os/release-info uses for the
# ISO link): set it to "owner/repo" of the repo whose Actions publish the bundle.
# To host the bundle elsewhere, point FOULFOX_APP_MANIFEST_URL at the manifest.
# FOULFOX_GITHUB_REPO=owner/repo
# FOULFOX_APP_MANIFEST_URL=
FOULFOX_APP_RELEASES_KEEP=2

# ── File explorer / USB frontload staging (drivers, isos, files) ─────────────
FRONTLOAD_STAGING_DIR=/var/lib/foulfox/frontload

# ── Windows guest display: a fullscreen SPICE viewer attaches on boot ────────
VM_DISPLAY_MODE=spice
VM_SPICE_PORT=5930

# ── Windows guest sizing (used by foulfox-first-run when writing VM config) ──
# "auto" = let foulfox-first-run size the guest to the detected hardware
# (conservative on a small machine, larger on a capable one) using the same
# planner the setup wizard shows. Pin a concrete value to override: a qcow2 size
# string for the disk (e.g. VM_DISK_SIZE=128G) and integers for RAM/CPU. Sizing
# is computed once, before the guest disk is created; an existing disk is left
# as-is. FOULFOX_DISK_RESERVE_GB (default 30) is held back for FoulFox OS + apps.
VM_RAM_GB=auto
VM_CPU_CORES=auto
VM_DISK_SIZE=auto
# FOULFOX_DISK_RESERVE_GB=30
